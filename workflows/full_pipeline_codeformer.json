{
  "_comment": "Dreamer — Full Pipeline: IPAdapter + ControlNet OpenPose + CodeFormer",
  "_version": "1.0.0",
  "_description": "Complete identity-preserving pipeline with pose control and face restoration post-processing.",

  "1": {
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load SDXL Checkpoint" }
  },

  "2": {
    "inputs": { "vae_name": "sdxl_vae.safetensors" },
    "class_type": "VAELoader",
    "_meta": { "title": "Load VAE" }
  },

  "3": {
    "inputs": {
      "image": "portrait.jpg",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "load_image_node" }
  },

  "4": {
    "inputs": {
      "ipadapter_file": "ip-adapter-faceid-plusv2_sdxl.bin"
    },
    "class_type": "IPAdapterModelLoader",
    "_meta": { "title": "Load IPAdapter FaceID" }
  },

  "5": {
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    },
    "class_type": "CLIPVisionLoader",
    "_meta": { "title": "Load CLIP Vision" }
  },

  "6": {
    "inputs": {
      "control_net_name": "OpenPoseXL2.safetensors"
    },
    "class_type": "ControlNetLoader",
    "_meta": { "title": "Load ControlNet OpenPose" }
  },

  "7": {
    "inputs": {
      "image": ["3", 0],
      "detect_hand": true,
      "detect_body": true,
      "detect_face": true,
      "resolution": 512
    },
    "class_type": "OpenposePreprocessor",
    "_meta": { "title": "Extract Pose Keypoints" }
  },

  "8": {
    "inputs": {
      "model": ["1", 0],
      "ipadapter": ["4", 0],
      "image": ["3", 0],
      "clip_vision": ["5", 0],
      "weight": 0.78,
      "weight_type": "linear",
      "start_at": 0.0,
      "end_at": 1.0,
      "faceid_v2": true,
      "weight_v2": 1.0
    },
    "class_type": "IPAdapterAdvanced",
    "_meta": { "title": "ipadapter_node" }
  },

  "9": {
    "inputs": {
      "text": "professional portrait photograph, with a gentle, warm smile, soft expression, studio lighting, sharp focus, photorealistic, high quality skin texture",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "positive_prompt_node" }
  },

  "10": {
    "inputs": {
      "text": "deformed, distorted, disfigured, bad anatomy, blurry, low quality, watermark, extra limbs, ugly",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "negative_prompt_node" }
  },

  "11": {
    "inputs": {
      "strength": 0.45,
      "start_percent": 0.0,
      "end_percent": 0.65,
      "positive": ["9", 0],
      "negative": ["10", 0],
      "control_net": ["6", 0],
      "image": ["7", 0]
    },
    "class_type": "ControlNetApplyAdvanced",
    "_meta": { "title": "Apply ControlNet Pose" }
  },

  "12": {
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": { "title": "empty_latent_node" }
  },

  "13": {
    "inputs": {
      "seed": 42,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.65,
      "model": ["8", 0],
      "positive": ["11", 0],
      "negative": ["11", 1],
      "latent_image": ["12", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "ksampler_node" }
  },

  "14": {
    "inputs": {
      "samples": ["13", 0],
      "vae": ["2", 0]
    },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },

  "15": {
    "inputs": {
      "fidelity_weight": 0.7,
      "upscale_factor": 1,
      "only_center_face": false,
      "image": ["14", 0]
    },
    "class_type": "CodeFormer",
    "_meta": { "title": "CodeFormer Face Restore" }
  },

  "16": {
    "inputs": {
      "filename_prefix": "portrait_full_pipeline",
      "images": ["15", 0]
    },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Output" }
  }
}
